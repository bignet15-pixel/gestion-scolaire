+                'trimestre',
+            ])
+            ->whereIn('inscription_id', $inscriptionIds)
+            ->where('visible_parent', true)
+            ->orderByDesc('created_at')
+            ->limit(8)
+            ->get();
+
+        return view('dashboard.parent', compact(
+            'enfants',
+            'inscriptions',
+            'totalFraisAttendus',
+            'totalFraisCollectes',
+            'totalRestant',
+            'absencesRetards',
+            'sanctions'
+        ));
+    }
