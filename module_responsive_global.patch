diff --git a/resources/css/app.css b/resources/css/app.css
index 93a73a0..036cbef 100644
--- a/resources/css/app.css
+++ b/resources/css/app.css
@@ -2738,3 +2738,561 @@ @media (max-width: 850px) {
         justify-content: flex-start;
     }
 }
+
+
+/* ==========================================================
+   Responsive global — navigation, tableaux et ergonomie mobile
+   ========================================================== */
+
+body.sidebar-open,
+body.modal-open {
+    overflow: hidden;
+}
+
+.topbar-title-block {
+    display: flex;
+    align-items: center;
+    gap: 14px;
+    min-width: 0;
+}
+
+.mobile-menu-toggle,
+.sidebar-close {
+    display: none;
+}
+
+.sidebar-overlay[hidden] {
+    display: none;
+}
+
+.sidebar-overlay {
+    position: fixed;
+    inset: 0;
+    z-index: 900;
+    background: rgba(15, 23, 42, 0.52);
+    -webkit-backdrop-filter: blur(2px);
+    backdrop-filter: blur(2px);
+}
+
+.brand-text {
+    min-width: 0;
+}
+
+.brand-title,
+.brand-subtitle,
+.page-title,
+.user-info strong,
+.user-info span {
+    overflow-wrap: anywhere;
+}
+
+.content,
+.card,
+.container,
+.main-area {
+    min-width: 0;
+}
+
+.responsive-table-shell,
+.table-responsive {
+    width: 100%;
+    overflow-x: auto;
+    -webkit-overflow-scrolling: touch;
+    border-radius: 14px;
+    border: 1px solid var(--border);
+    background: var(--white);
+}
+
+.responsive-table-shell .table,
+.table-responsive .table {
+    margin: 0;
+    border-radius: 0;
+}
+
+.responsive-table-shell:focus,
+.table-responsive:focus-within {
+    outline: 3px solid rgba(30, 58, 138, 0.14);
+    outline-offset: 2px;
+}
+
+.table {
+    table-layout: auto;
+}
+
+.table th,
+.table td {
+    overflow-wrap: anywhere;
+}
+
+.table td:last-child,
+.table th:last-child {
+    white-space: nowrap;
+}
+
+.table-actions {
+    justify-content: flex-start;
+}
+
+.table-actions .btn,
+.table td:last-child .btn {
+    min-width: max-content;
+}
+
+.card > .table,
+.container > .table {
+    margin-top: 10px;
+}
+
+@media (max-width: 1180px) {
+    .dashboard-grid,
+    .finance-grid {
+        grid-template-columns: repeat(2, minmax(0, 1fr));
+    }
+
+    .finance-header,
+    .parent-summary-header,
+    .page-header,
+    .card-header,
+    .request-detail-hero,
+    .request-detail-titlebar {
+        gap: 16px;
+    }
+}
+
+@media (max-width: 1024px) {
+    .app-shell {
+        display: block;
+    }
+
+    .sidebar {
+        position: fixed;
+        inset: 0 auto 0 0;
+        width: min(86vw, 330px);
+        height: 100vh;
+        z-index: 1001;
+        transform: translateX(-105%);
+        transition: transform 0.22s ease;
+        box-shadow: 22px 0 70px rgba(15, 23, 42, 0.28);
+        padding-bottom: 32px;
+    }
+
+    .sidebar.is-open {
+        transform: translateX(0);
+    }
+
+    .sidebar-brand {
+        position: sticky;
+        top: -22px;
+        z-index: 2;
+        background: linear-gradient(180deg, var(--primary-dark), var(--primary));
+        padding-top: 4px;
+    }
+
+    .sidebar-close {
+        display: inline-flex;
+        align-items: center;
+        justify-content: center;
+        width: 38px;
+        height: 38px;
+        margin-left: auto;
+        border: 1px solid rgba(255, 255, 255, 0.26);
+        border-radius: 12px;
+        background: rgba(255, 255, 255, 0.12);
+        color: #ffffff;
+        font-size: 26px;
+        font-weight: 900;
+        cursor: pointer;
+    }
+
+    .main-area {
+        margin-left: 0;
+    }
+
+    .topbar {
+        min-height: auto;
+        padding: 14px 18px;
+        gap: 14px;
+        align-items: flex-start;
+        flex-wrap: wrap;
+    }
+
+    .mobile-menu-toggle {
+        display: inline-flex;
+        align-items: center;
+        justify-content: center;
+        gap: 8px;
+        min-height: 42px;
+        padding: 9px 12px;
+        border: 1px solid #cbd5e1;
+        border-radius: 12px;
+        background: var(--white);
+        color: var(--primary-dark);
+        font-weight: 900;
+        cursor: pointer;
+        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.07);
+    }
+
+    .mobile-menu-toggle span {
+        font-size: 18px;
+        line-height: 1;
+    }
+
+    .content {
+        padding: 20px 18px 32px;
+    }
+
+    .user-box {
+        flex-wrap: wrap;
+        justify-content: flex-end;
+        gap: 8px;
+    }
+
+    .finance-header,
+    .parent-summary-header,
+    .request-detail-hero,
+    .request-detail-titlebar,
+    .filters-row,
+    .actions-row {
+        flex-direction: column;
+        align-items: stretch;
+    }
+
+    .request-detail-side {
+        position: static;
+    }
+
+    .table-responsive > .table,
+    .responsive-table-shell > .table {
+        min-width: 760px;
+    }
+
+    .planning-grid-table {
+        display: none !important;
+    }
+
+    .planning-mobile-list {
+        display: grid;
+        gap: 14px;
+    }
+}
+
+@media (max-width: 780px) {
+    .topbar {
+        position: sticky;
+        top: 0;
+    }
+
+    .topbar-title-block {
+        width: 100%;
+        align-items: flex-start;
+    }
+
+    .page-title {
+        font-size: 19px;
+        line-height: 1.25;
+    }
+
+    .page-kicker {
+        font-size: 11px;
+    }
+
+    .user-box {
+        width: 100%;
+        display: grid;
+        grid-template-columns: 1fr 1fr;
+        align-items: stretch;
+    }
+
+    .user-info {
+        grid-column: 1 / -1;
+        text-align: left;
+        padding: 10px 12px;
+        border: 1px solid var(--border);
+        border-radius: 12px;
+        background: #f8fafc;
+    }
+
+    .user-box .btn,
+    .user-box form,
+    .user-box form .btn {
+        width: 100%;
+    }
+
+    .content {
+        padding: 16px 12px 28px;
+    }
+
+    .container {
+        max-width: 100%;
+    }
+
+    .card,
+    .finance-panel,
+    .stat-card,
+    .request-panel,
+    .decision-box,
+    .processed-box {
+        border-radius: 14px;
+        padding: 16px;
+        margin-bottom: 16px;
+    }
+
+    .card h1,
+    .container > h1 {
+        font-size: 21px;
+        line-height: 1.25;
+    }
+
+    .card h2 {
+        font-size: 17px;
+    }
+
+    .dashboard-grid,
+    .finance-grid,
+    .form-grid,
+    .request-info-grid,
+    .request-detail-grid,
+    .request-panel-two,
+    .parent-justification-panel,
+    .notification-item {
+        grid-template-columns: 1fr !important;
+    }
+
+    .finance-rate {
+        width: 100%;
+        min-width: 0;
+    }
+
+    .btn,
+    .form-actions .btn,
+    .notification-actions .btn,
+    .request-decision-card .btn,
+    .parent-justification-submit .btn {
+        width: 100%;
+        min-height: 42px;
+    }
+
+    .form-actions,
+    .notification-actions,
+    .request-row-actions,
+    .confirm-modal-actions {
+        display: grid;
+        grid-template-columns: 1fr;
+        width: 100%;
+    }
+
+    .table {
+        display: table;
+        overflow: visible;
+        white-space: normal;
+    }
+
+    .table th,
+    .table td {
+        padding: 11px 12px;
+        font-size: 13px;
+    }
+
+    .responsive-table-shell,
+    .table-responsive {
+        margin: 10px 0 2px;
+    }
+
+    .auth-page {
+        padding: 14px;
+    }
+
+    .auth-card {
+        min-height: 0;
+        border-radius: 18px;
+    }
+
+    .auth-panel,
+    .auth-form-panel {
+        padding: 24px 18px;
+    }
+
+    .auth-panel h1,
+    .auth-form-panel h2 {
+        font-size: 25px;
+    }
+
+    .confirm-modal-dialog {
+        padding: 22px 16px;
+    }
+}
+
+@media (max-width: 640px) {
+    .sidebar {
+        width: min(92vw, 330px);
+    }
+
+    .brand-logo {
+        width: 40px;
+        height: 40px;
+        border-radius: 10px;
+        font-size: 16px;
+    }
+
+    .brand-title {
+        font-size: 15px;
+    }
+
+    .sidebar-link {
+        min-height: 42px;
+        display: flex;
+        align-items: center;
+        justify-content: space-between;
+    }
+
+    .stat-value,
+    .finance-rate span {
+        font-size: 25px;
+    }
+
+    .mobile-menu-toggle {
+        padding: 8px 10px;
+    }
+
+    .responsive-card-table {
+        min-width: 0 !important;
+        width: 100%;
+        border-collapse: separate;
+        border-spacing: 0 12px;
+        background: transparent;
+    }
+
+    .responsive-card-table thead {
+        display: none;
+    }
+
+    .responsive-card-table,
+    .responsive-card-table tbody,
+    .responsive-card-table tr,
+    .responsive-card-table td {
+        display: block;
+        width: 100%;
+    }
+
+    .responsive-card-table tbody tr {
+        border: 1px solid var(--border);
+        border-radius: 14px;
+        background: #ffffff;
+        box-shadow: 0 10px 22px rgba(15, 23, 42, 0.06);
+        overflow: hidden;
+        margin-bottom: 12px;
+    }
+
+    .responsive-card-table tbody tr:nth-child(even),
+    .responsive-card-table tbody tr:hover {
+        background: #ffffff;
+    }
+
+    .responsive-card-table td {
+        display: grid;
+        grid-template-columns: minmax(105px, 38%) minmax(0, 1fr);
+        gap: 12px;
+        align-items: start;
+        border-bottom: 1px solid #eef2f7;
+        padding: 11px 12px;
+        white-space: normal !important;
+    }
+
+    .responsive-card-table td:last-child {
+        border-bottom: 0;
+    }
+
+    .responsive-card-table td::before {
+        content: attr(data-label);
+        color: var(--muted);
+        font-size: 11px;
+        font-weight: 900;
+        text-transform: uppercase;
+        letter-spacing: .04em;
+    }
+
+    .responsive-card-table td[data-label=""],
+    .responsive-card-table td:not([data-label]) {
+        grid-template-columns: 1fr;
+    }
+
+    .responsive-card-table td[data-label=""]::before,
+    .responsive-card-table td:not([data-label])::before {
+        content: none;
+    }
+
+    .responsive-card-table .table-actions,
+    .responsive-card-table td:last-child {
+        display: grid;
+        grid-template-columns: 1fr;
+        gap: 8px;
+    }
+
+    .responsive-card-table .table-actions .btn,
+    .responsive-card-table td:last-child .btn,
+    .responsive-card-table td:last-child form {
+        width: 100%;
+    }
+
+    .note-table,
+    .planning-detail-table,
+    .table-responsive > .table:not(.responsive-card-table),
+    .responsive-table-shell > .table:not(.responsive-card-table) {
+        min-width: 720px;
+    }
+
+    .planning-mobile-item-head,
+    .planning-mobile-meta {
+        flex-direction: column;
+        align-items: flex-start;
+    }
+
+    .planning-mobile-meta strong {
+        text-align: left;
+    }
+
+    input[type="file"]::file-selector-button {
+        width: 100%;
+        margin: 0 0 8px;
+    }
+}
+
+@media (max-width: 430px) {
+    .content {
+        padding-left: 10px;
+        padding-right: 10px;
+    }
+
+    .card,
+    .stat-card,
+    .finance-item,
+    .request-info-grid > div {
+        padding: 14px;
+    }
+
+    .user-box {
+        grid-template-columns: 1fr;
+    }
+
+    .topbar-title-block {
+        gap: 10px;
+    }
+
+    .mobile-menu-toggle {
+        min-width: 44px;
+        font-size: 0;
+    }
+
+    .mobile-menu-toggle span {
+        font-size: 20px;
+    }
+
+    .responsive-card-table td {
+        grid-template-columns: 1fr;
+        gap: 5px;
+    }
+
+    .responsive-card-table td::before {
+        font-size: 10px;
+    }
+}
